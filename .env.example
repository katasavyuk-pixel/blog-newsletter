# --- Sitio ---
# Base URL absoluta (metadataBase / canonical / enlaces de email). En prod: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (proyecto en región eu-central-1, Frankfurt) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=     # nueva API key "publishable" (reemplaza la anon key)
SUPABASE_SERVICE_ROLE_KEY=                # SOLO servidor — NUNCA con prefijo NEXT_PUBLIC, nunca en el cliente

# --- Añadidos en fases siguientes (placeholders por ahora) ---
# Fase 2 — Newsletter (Resend + doble opt-in)
# RESEND_API_KEY=                         # key scoped a "sending"
# RESEND_FROM=news@news.tudominio.com     # subdominio dedicado, región eu-west-1
# Fase 2 — Anti-abuso del formulario público
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Analítica (cookieless, EU)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SRC=

# Valores reales: Doppler (dev) / `vercel env` (prod). Nunca commitear secretos.
