# --- Sitio ---
# Base URL absoluta (metadataBase / canonical / enlaces de email). En prod: https://kata.ianexora.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (proyecto en región eu-central-1, Frankfurt) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=     # nueva API key "publishable" (reemplaza la anon key)
SUPABASE_SERVICE_ROLE_KEY=                # SOLO servidor — NUNCA con prefijo NEXT_PUBLIC, nunca en el cliente

# --- Resend (newsletter, Fase 2) ---
RESEND_API_KEY=                           # key scoped a "sending"
# Hasta verificar el subdominio en Resend, usar onboarding@resend.dev (modo test).
# Tras verificar news.ianexora.com:
RESEND_FROM=Kata Ivanovych <news@news.ianexora.com>

# --- Cloudflare Turnstile (anti-abuso del formulario, Fase 2) ---
# Si se dejan vacías, el anti-abuso queda desactivado (el flujo sigue funcionando).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Analítica cookieless (opcional) ---
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_SRC=

# Valores reales: Doppler (dev) / `vercel env` (prod). Nunca commitear secretos.
